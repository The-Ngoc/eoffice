{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.25/MicrosoftTeams.schema.json",
    "manifestVersion": "1.25",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "eoffice_DUT",
        "websiteUrl": "https://eoffice-hazel.vercel.app",
        "privacyUrl": "https://www.microsoft.com/en-us/privacy/privacystatement",
        "termsOfUseUrl": "https://www.microsoft.com/en-us/servicesagreement"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "eoffice-teams${{APP_NAME_SUFFIX}}",
        "full": "Full name for eoffice-teams"
    },
    "description": {
        "short": "App demo eOffice",
        "full": "Ứng dụng văn phòng điện tử tích hợp với Microsoft Teams, cung cấp các tính năng quản lý công việc, tài liệu và giao tiếp hiệu quả cho người dùng."
    },
    "accentColor": "#FFFFFF",
    "supportsChannelFeatures": "tier1",
    "bots": [],
    "composeExtensions": [],
    "staticTabs": [
        {
            "entityId": "index0",
            "name": "Home",
            "contentUrl": "${{TAB_ENDPOINT}}/tabs/home",
            "websiteUrl": "${{TAB_ENDPOINT}}/tabs/home",
            "scopes": [
                "personal",
                "groupChat",
                "team"
            ]
        }
    ],
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": [
        "${{TAB_DOMAIN}}"
    ]
}