{
  "name": "eofficeteams",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index",
  "types": "dist/index",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:teamsfx": "env-cmd --silent -f .localConfigs npm run dev",
    "clean": "rimraf ./dist",
    "build": "tsup && npm run build:frontend",
    "build:frontend": "vite build --outDir dist/client",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@microsoft/teams-js": "^2.52.0",
    "@microsoft/teamsfx": "^4.0.3",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.15.0",
    "dotenv": "^17.2.3",
    "env-cmd": "^11.0.0",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "nodemon": "^3.1.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
